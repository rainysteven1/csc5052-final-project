# Copy this file to `.env` and fill only the values you actually use.
#
# Example:
#   cp .env.example .env

########################################
# Core Paths
########################################

# Optional. Usually auto-detected.
# SPEAKSURE_REPO_ROOT=/home/nn/workspace/csc5052/final-project
# SPEAKSURE_AGENT_SERVICE_ROOT=/home/nn/workspace/csc5052/final-project/services/agent
# SPEAKSURE_AGENT_CONFIG_ROOT=/home/nn/workspace/csc5052/final-project/services/agent/config
# SPEAKSURE_AGENT_DATA_ROOT=/home/nn/workspace/csc5052/final-project/services/agent/data
# SPEAKSURE_CONFIG_PATH=/home/nn/workspace/csc5052/final-project/services/agent/config/config.toml

########################################
# Agent Transport
########################################

# The main runtime toggle that is expected to change often.
# Agent -> ASR transport mode:
#   local = in-process monolith
#   grpc  = call services/asr over gRPC
#   api   = call teammate HTTP ASR API
#   stub  = fallback transcript
SPEAKSURE_ASR_PROVIDER=local

########################################
# Remote ASR API
########################################

# These rarely change. Prefer putting their stable values in
# `services/agent/config/config.toml`, not in `.env`.
#
# Optional timeout for teammate HTTP ASR API
SPEAKSURE_ASR_TIMEOUT_SECONDS=60

# Optional auth for teammate HTTP ASR API
# SPEAKSURE_ASR_API_KEY=
# SPEAKSURE_ASR_AUTH_HEADER=Authorization

########################################
# MiniMax LLM
########################################

# Used by reasoning / feedback nodes
# MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.chat/v1
SPEAKSURE_LLM_MODEL=MiniMax-M2.7-highspeed

########################################
# Weights & Biases
########################################

WANDB_MODE=disabled
# WANDB_API_KEY=
# WANDB_PROJECT=speaksure-runtime
# WANDB_ENTITY=

########################################
# Hugging Face Downloads
########################################

# Optional. Useful for gated model downloads such as pyannote.
# HF_TOKEN=
